<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Catppuccin Mocha palette — https://catppuccin.com/palette  -->
    <Color x:Key="Mocha.Rosewater">#F5E0DC</Color>
    <Color x:Key="Mocha.Flamingo">#F2CDCD</Color>
    <Color x:Key="Mocha.Pink">#F5C2E7</Color>
    <Color x:Key="Mocha.Mauve">#CBA6F7</Color>
    <Color x:Key="Mocha.Red">#F38BA8</Color>
    <Color x:Key="Mocha.Maroon">#EBA0AC</Color>
    <Color x:Key="Mocha.Peach">#FAB387</Color>
    <Color x:Key="Mocha.Yellow">#F9E2AF</Color>
    <Color x:Key="Mocha.Green">#A6E3A1</Color>
    <Color x:Key="Mocha.Teal">#94E2D5</Color>
    <Color x:Key="Mocha.Sky">#89DCEB</Color>
    <Color x:Key="Mocha.Sapphire">#74C7EC</Color>
    <Color x:Key="Mocha.Blue">#89B4FA</Color>
    <Color x:Key="Mocha.Lavender">#B4BEFE</Color>

    <Color x:Key="Mocha.Text">#CDD6F4</Color>
    <Color x:Key="Mocha.Subtext1">#BAC2DE</Color>
    <Color x:Key="Mocha.Subtext0">#A6ADC8</Color>
    <Color x:Key="Mocha.Overlay2">#9399B2</Color>
    <Color x:Key="Mocha.Overlay1">#7F849C</Color>
    <Color x:Key="Mocha.Overlay0">#6C7086</Color>
    <Color x:Key="Mocha.Surface2">#585B70</Color>
    <Color x:Key="Mocha.Surface1">#45475A</Color>
    <Color x:Key="Mocha.Surface0">#313244</Color>
    <Color x:Key="Mocha.Base">#1E1E2E</Color>
    <Color x:Key="Mocha.Mantle">#181825</Color>
    <Color x:Key="Mocha.Crust">#11111B</Color>

    <!--  Brushes consumed by controls  -->
    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Mocha.Base}" Opacity="0.92" />
    <SolidColorBrush x:Key="Brush.Window.Border" Color="{StaticResource Mocha.Surface1}" />
    <SolidColorBrush x:Key="Brush.Card.Background" Color="{StaticResource Mocha.Mantle}" Opacity="0.88" />
    <SolidColorBrush x:Key="Brush.Card.Border" Color="{StaticResource Mocha.Surface0}" />
    <SolidColorBrush x:Key="Brush.Card.HeaderText" Color="{StaticResource Mocha.Lavender}" />
    <SolidColorBrush x:Key="Brush.Card.BodyText" Color="{StaticResource Mocha.Text}" />
    <SolidColorBrush x:Key="Brush.Card.SubtleText" Color="{StaticResource Mocha.Subtext0}" />
    <!-- F-A19: Overlay1 #7F849C on Mantle #181825@0.88 was ~4.2:1 — below WCAG AA.
         Overlay2 #9399B2 measured ≥ 4.5:1 against the actual rendered background. -->
    <SolidColorBrush x:Key="Brush.Card.MutedText" Color="{StaticResource Mocha.Overlay2}" />

    <SolidColorBrush x:Key="Brush.Ring.Track" Color="{StaticResource Mocha.Surface1}" />
    <SolidColorBrush x:Key="Brush.Ring.Safe" Color="{StaticResource Mocha.Green}" />
    <SolidColorBrush x:Key="Brush.Ring.Warn" Color="{StaticResource Mocha.Peach}" />
    <SolidColorBrush x:Key="Brush.Ring.Danger" Color="{StaticResource Mocha.Red}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Mocha.Mauve}" />
    <SolidColorBrush x:Key="Brush.Accent.Soft" Color="{StaticResource Mocha.Lavender}" Opacity="0.2" />

    <!--  Typography  -->
    <FontFamily x:Key="Font.Default">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>

</ResourceDictionary>
