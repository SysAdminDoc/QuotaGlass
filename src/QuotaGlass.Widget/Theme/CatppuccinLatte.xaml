<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Catppuccin Latte palette — https://catppuccin.com/palette  -->
    <!--  Mirrors the keys in CatppuccinMocha.xaml so a swap is dictionary-level only.  -->
    <Color x:Key="Mocha.Rosewater">#DC8A78</Color>
    <Color x:Key="Mocha.Flamingo">#DD7878</Color>
    <Color x:Key="Mocha.Pink">#EA76CB</Color>
    <Color x:Key="Mocha.Mauve">#8839EF</Color>
    <Color x:Key="Mocha.Red">#D20F39</Color>
    <Color x:Key="Mocha.Maroon">#E64553</Color>
    <Color x:Key="Mocha.Peach">#FE640B</Color>
    <Color x:Key="Mocha.Yellow">#DF8E1D</Color>
    <Color x:Key="Mocha.Green">#40A02B</Color>
    <Color x:Key="Mocha.Teal">#179299</Color>
    <Color x:Key="Mocha.Sky">#04A5E5</Color>
    <Color x:Key="Mocha.Sapphire">#209FB5</Color>
    <Color x:Key="Mocha.Blue">#1E66F5</Color>
    <Color x:Key="Mocha.Lavender">#7287FD</Color>

    <Color x:Key="Mocha.Text">#4C4F69</Color>
    <Color x:Key="Mocha.Subtext1">#5C5F77</Color>
    <Color x:Key="Mocha.Subtext0">#6C6F85</Color>
    <Color x:Key="Mocha.Overlay2">#7C7F93</Color>
    <Color x:Key="Mocha.Overlay1">#8C8FA1</Color>
    <Color x:Key="Mocha.Overlay0">#9CA0B0</Color>
    <Color x:Key="Mocha.Surface2">#ACB0BE</Color>
    <Color x:Key="Mocha.Surface1">#BCC0CC</Color>
    <Color x:Key="Mocha.Surface0">#CCD0DA</Color>
    <Color x:Key="Mocha.Base">#EFF1F5</Color>
    <Color x:Key="Mocha.Mantle">#E6E9EF</Color>
    <Color x:Key="Mocha.Crust">#DCE0E8</Color>

    <!--  Brushes consumed by controls  -->
    <SolidColorBrush x:Key="Brush.Window.Background" Color="{StaticResource Mocha.Base}" Opacity="0.95" />
    <SolidColorBrush x:Key="Brush.Window.MicaBackground" Color="{StaticResource Mocha.Base}" Opacity="0.35" />
    <SolidColorBrush x:Key="Brush.Window.Border" Color="{StaticResource Mocha.Surface1}" />
    <SolidColorBrush x:Key="Brush.Card.Background" Color="{StaticResource Mocha.Mantle}" Opacity="0.92" />
    <SolidColorBrush x:Key="Brush.Card.Border" Color="{StaticResource Mocha.Surface0}" />
    <SolidColorBrush x:Key="Brush.Card.HeaderText" Color="{StaticResource Mocha.Mauve}" />
    <SolidColorBrush x:Key="Brush.Card.BodyText" Color="{StaticResource Mocha.Text}" />
    <SolidColorBrush x:Key="Brush.Card.SubtleText" Color="{StaticResource Mocha.Subtext1}" />
    <!-- Latte: Subtext0 #6C6F85 on Mantle #E6E9EF@0.92 measures > 4.5:1 -->
    <SolidColorBrush x:Key="Brush.Card.MutedText" Color="{StaticResource Mocha.Subtext0}" />

    <SolidColorBrush x:Key="Brush.Ring.Track" Color="{StaticResource Mocha.Surface1}" />
    <SolidColorBrush x:Key="Brush.Ring.Safe" Color="{StaticResource Mocha.Green}" />
    <SolidColorBrush x:Key="Brush.Ring.Warn" Color="{StaticResource Mocha.Peach}" />
    <SolidColorBrush x:Key="Brush.Ring.Danger" Color="{StaticResource Mocha.Red}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Mocha.Mauve}" />
    <SolidColorBrush x:Key="Brush.Accent.Soft" Color="{StaticResource Mocha.Lavender}" Opacity="0.2" />

    <!--  Typography  -->
    <FontFamily x:Key="Font.Default">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Cascadia Mono, Consolas</FontFamily>

</ResourceDictionary>
