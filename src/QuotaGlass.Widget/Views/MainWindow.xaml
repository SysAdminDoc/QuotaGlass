<Window x:Class="QuotaGlass.Widget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:QuotaGlass.Widget.Controls"
        xmlns:v="clr-namespace:QuotaGlass.Widget.Views"
        xmlns:vm="clr-namespace:QuotaGlass.Widget.ViewModels"
        Title="QuotaGlass"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual"
        Left="40"
        Top="40">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Border Style="{StaticResource WindowChromeBorder}"
            MouseLeftButtonDown="OnChromeMouseDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.42" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="8"
                            Height="8"
                            CornerRadius="4"
                            Background="{StaticResource Brush.Accent.Strong}"
                            Margin="0,0,8,0" />
                    <StackPanel>
                        <TextBlock Style="{StaticResource HeaderText}" Text="QuotaGlass" />
                        <TextBlock Style="{StaticResource CaptionText}" Text="Usage window monitor" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="–"
                            Style="{StaticResource IconButton}"
                            Click="OnMinimizeClick"
                            ToolTip="Minimize"
                            AutomationProperties.Name="Minimize" />
                    <Button Content="×"
                            Style="{StaticResource IconButton}"
                            Click="OnCloseClick"
                            ToolTip="Hide widget"
                            AutomationProperties.Name="Hide widget" />
                </StackPanel>
            </Grid>

            <v:SetupCardView Grid.Row="1" DataContext="{Binding Setup}" />

            <Border Grid.Row="2"
                    Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Style="{StaticResource HeaderText}" Text="Waiting for usage data" />
                    <TextBlock Style="{StaticResource SubText}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Text="QuotaGlass will populate this space as soon as the extension or local credential poller sends a snapshot." />
                    <TextBlock Style="{StaticResource CaptionText}"
                               Margin="0,8,0,0"
                               Text="Tip: use the setup card above if this is your first run." />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="2"
                          MaxHeight="260"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasBuckets, Converter={StaticResource BoolToVisibility}}">
                <ItemsControl ItemsSource="{Binding Buckets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:BucketViewModel}">
                            <Border Style="{StaticResource InteractiveCardBorder}"
                                    Cursor="Hand"
                                    Focusable="True"
                                    KeyboardNavigation.IsTabStop="True"
                                    MouseLeftButtonUp="OnCardClicked"
                                    MouseRightButtonUp="OnCardRightClicked"
                                    KeyDown="OnCardKeyDown"
                                    AutomationProperties.Name="{Binding HoverTooltip}"
                                    AutomationProperties.HelpText="Enter opens analytics. Shift F10 opens snooze actions.">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="260">
                                            <TextBlock Style="{StaticResource HeaderText}" Text="{Binding HoverTooltip}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource SubText}"
                                                       Margin="0,6,0,0"
                                                       Text="{Binding PaceLabel}"
                                                       Visibility="{Binding HasPace, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBlock Style="{StaticResource CaptionText}"
                                                       Margin="0,6,0,0"
                                                       Text="Click opens analytics. Right-click opens snooze actions." />
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Width="82"
                                      Height="82"
                                      Margin="0,0,14,0"
                                      Opacity="{Binding StaleOpacity}">
                                    <c:RadialRing Percent="{Binding Percent}"
                                                  Thickness="9"
                                                  PaceMarkerPercent="{Binding PaceMarkerPercent}"
                                                  WarnPercent="{Binding DataContext.Settings.WarnPercent, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                  DangerPercent="{Binding DataContext.Settings.DangerPercent, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                  ReducedMotion="{Binding DataContext.ReducedMotion, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                  TrackBrush="{StaticResource Brush.Ring.Track}"
                                                  SafeBrush="{StaticResource Brush.Ring.Safe}"
                                                  WarnBrush="{StaticResource Brush.Ring.Warn}"
                                                  DangerBrush="{StaticResource Brush.Ring.Danger}" />
                                    <Viewbox Stretch="Uniform" Margin="15">
                                        <TextBlock Style="{StaticResource RingCenter}" Text="{Binding TimeUntilResetLabel}" />
                                    </Viewbox>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Style="{StaticResource HeaderText}"
                                                   Text="{Binding Label}"
                                                   TextWrapping="NoWrap" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource SubText}"
                                                   Margin="8,0,0,0"
                                                   Text="{Binding PercentLabel}" />
                                    </Grid>

                                    <WrapPanel Margin="0,5,0,0">
                                        <Border Style="{StaticResource PillBorder}" Margin="0,0,6,4">
                                            <TextBlock Style="{StaticResource PillText}" Text="{Binding Provider}" />
                                        </Border>
                                        <Border Style="{StaticResource PillBorder}" Margin="0,0,6,4">
                                            <TextBlock Style="{StaticResource PillText}" Text="{Binding KindBadge}" />
                                        </Border>
                                        <Border Style="{StaticResource PillBorder}"
                                                Margin="0,0,6,4"
                                                Visibility="{Binding HasAccountLabel, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Style="{StaticResource PillText}" Text="{Binding AccountLabel}" />
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Style="{StaticResource SubText}" Text="{Binding ResetAtLabel}" />
                                    <TextBlock Style="{StaticResource SubText}"
                                               Margin="0,3,0,0"
                                               Text="{Binding PaceLabel}"
                                               Visibility="{Binding HasPace, Converter={StaticResource BoolToVisibility}}" />
                                    <c:Sparkline Samples="{Binding SparklineData}"
                                                 LineBrush="{StaticResource Brush.Card.MutedText}"
                                                 Height="18"
                                                 Margin="0,7,0,0"
                                                 Visibility="{Binding HasSparkline, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Margin="0,2,0,0">
                <Button Style="{StaticResource HitButton}"
                        Content="{Binding Settings.ToggleLabel}"
                        Click="OnToggleSettings"
                        HorizontalAlignment="Right"
                        ToolTip="Show or hide preferences" />

                <Border Style="{StaticResource CardBorder}"
                        Margin="0,4,0,0"
                        Visibility="{Binding Settings.IsExpanded, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <Expander Header="Alarms" IsExpanded="True" Foreground="{StaticResource Brush.Card.HeaderText}">
                            <StackPanel Margin="0,8,0,10">
                                <TextBlock Style="{StaticResource SubText}"
                                           Margin="0,0,0,8"
                                           Text="Choose when QuotaGlass interrupts you and how each alarm sounds." />
                                <CheckBox Content="Enable notification alarms"
                                          Margin="0,0,0,6"
                                          IsChecked="{Binding Settings.AlarmsEnabled}" />
                                <CheckBox Content="Warn when pace will exhaust a window"
                                          Margin="0,0,0,6"
                                          ToolTip="Sends one pace toast per reset window when burn rate predicts exhaustion before reset."
                                          IsChecked="{Binding Settings.PaceEnabled}" />
                                <CheckBox Content="Respect Focus Assist and fullscreen modes"
                                          Margin="0,0,0,8"
                                          ToolTip="Suppresses alarm toasts while Focus Assist, fullscreen apps, or presentation mode are active."
                                          IsChecked="{Binding Settings.RespectFocusAssist}" />

                                <TextBlock Style="{StaticResource SubText}"
                                           Text="Alarm ladder"
                                           Margin="0,4,0,2" />
                                <ItemsControl ItemsSource="{Binding Settings.LadderTiers}" Margin="0,2,0,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:LadderTierViewModel}">
                                            <CheckBox Content="{Binding Label}"
                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                      Margin="0,2,10,2"
                                                      ToolTip="Toggle this lead-time toast" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SubText}" VerticalAlignment="Center" Text="Alarm sound" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis" Text="{Binding Settings.CustomWavLabel}" />
                                    <Button Grid.Column="2" Style="{StaticResource HitButton}" Content="Choose" Click="OnPickWavClicked" />
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SubText}" VerticalAlignment="Center" Text="Reset sound" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis" Text="{Binding Settings.ResetWavLabel}" />
                                    <Button Grid.Column="2" Style="{StaticResource HitButton}" Content="Choose" Click="OnPickResetWavClicked" />
                                </Grid>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SubText}" VerticalAlignment="Center" Text="Exhausted sound" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CaptionText}" VerticalAlignment="Center" Margin="8,0" TextTrimming="CharacterEllipsis" Text="{Binding Settings.ZeroStateWavLabel}" />
                                    <Button Grid.Column="2" Style="{StaticResource HitButton}" Content="Choose" Click="OnPickZeroStateWavClicked" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Display" IsExpanded="False" Foreground="{StaticResource Brush.Card.HeaderText}" Margin="0,4,0,0">
                            <StackPanel Margin="0,8,0,10">
                                <TextBlock Style="{StaticResource SubText}" Margin="0,0,0,8" Text="Tune theme and ring color thresholds." />
                                <WrapPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RadioButton Content="Mocha" Margin="0,0,12,4" GroupName="QGTheme" IsChecked="{Binding Settings.IsDarkTheme, Mode=TwoWay}" />
                                    <RadioButton Content="Latte" Margin="0,0,12,4" GroupName="QGTheme" IsChecked="{Binding Settings.IsLightTheme, Mode=TwoWay}" />
                                    <RadioButton Content="High contrast" Margin="0,0,12,4" GroupName="QGTheme" IsChecked="{Binding Settings.IsHighContrastTheme, Mode=TwoWay}" />
                                    <RadioButton Content="System" Margin="0,0,0,4" GroupName="QGTheme" IsChecked="{Binding Settings.IsSystemTheme, Mode=TwoWay}" />
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource SubText}" Text="Warn at %" />
                                        <TextBox Style="{StaticResource FieldTextBox}"
                                                 Text="{Binding Settings.WarnPercent, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="Ring turns warm above this percentage." />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Style="{StaticResource SubText}" Text="Danger at %" />
                                        <TextBox Style="{StaticResource FieldTextBox}"
                                                 Text="{Binding Settings.DangerPercent, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="Ring turns red above this percentage." />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Integration" IsExpanded="False" Foreground="{StaticResource Brush.Card.HeaderText}" Margin="0,4,0,0">
                            <StackPanel Margin="0,8,0,10">
                                <TextBlock Style="{StaticResource SubText}" Margin="0,0,0,8" Text="Startup and automation hooks for power users." />
                                <CheckBox Content="Launch QuotaGlass at logon"
                                          Margin="0,0,0,8"
                                          IsChecked="{Binding Settings.Autostart}" />
                                <TextBlock Style="{StaticResource SubText}"
                                           Text="Webhook command"
                                           ToolTip="Runs with cmd /c on each alarm fire. Env vars: QG_PROVIDER, QG_BUCKET_ID, QG_PERCENT, QG_RESET_ISO, QG_TIER." />
                                <TextBox Style="{StaticResource FieldTextBox}"
                                         Text="{Binding Settings.WebhookCommand, UpdateSourceTrigger=LostFocus}"
                                         ToolTip="Example: curl -d &quot;%QG_PROVIDER% at %QG_PERCENT%%%&quot; https://ntfy.sh/your-topic" />
                                <TextBlock Style="{StaticResource CaptionText}"
                                           Margin="0,4,0,0"
                                           Text="Runs for at most 5 seconds and receives quota details through QG_* environment variables." />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Advanced" IsExpanded="False" Foreground="{StaticResource Brush.Card.HeaderText}" Margin="0,4,0,0">
                            <StackPanel Margin="0,8,0,10">
                                <v:CalendarPanelView DataContext="{Binding Calendar}" />
                                <v:LogPanelView DataContext="{Binding LogPanel}" />

                                <Border Height="1" Background="{StaticResource Brush.Card.Divider}" Margin="0,10,0,8" />
                                <Button Style="{StaticResource HitButton}"
                                        Content="Reset settings"
                                        Click="OnResetSettings"
                                        HorizontalAlignment="Left"
                                        ToolTip="Restores alarm ladder, thresholds, theme, and integration settings. Position and autostart are preserved." />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="4" Margin="0,4,0,0" CornerRadius="8" Padding="8,5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource Brush.Accent.Soft}" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Card.Divider}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusKind}" Value="stale">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Status.Warning}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="very-stale">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Status.Danger}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusKind}" Value="error">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.Status.Danger}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Style="{StaticResource CaptionText}" Text="{Binding StatusText}" />
            </Border>
        </Grid>
    </Border>
</Window>
