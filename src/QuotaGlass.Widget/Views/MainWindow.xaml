<Window x:Class="QuotaGlass.Widget.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:QuotaGlass.Widget.Controls"
        xmlns:vm="clr-namespace:QuotaGlass.Widget.ViewModels"
        Title="QuotaGlass"
        Width="340"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual"
        Left="40"
        Top="40">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="HitButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Card.MutedText}" />
            <Setter Property="FontFamily" Value="{StaticResource Font.Default}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource Brush.Accent.Soft}" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Card.HeaderText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource WindowChromeBorder}"
            MouseLeftButtonDown="OnChromeMouseDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Title bar  -->
            <Grid Grid.Row="0" Margin="2,0,2,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{StaticResource HeaderText}"
                           Text="QuotaGlass"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="–" Style="{StaticResource HitButton}" Click="OnMinimizeClick" ToolTip="Minimize" />
                    <Button Content="×" Style="{StaticResource HitButton}" Click="OnCloseClick" ToolTip="Hide widget" />
                </StackPanel>
            </Grid>

            <!--  Setup checklist (F-N3) — visible only when something is unmet  -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Visibility="{Binding Setup.IsVisible, Converter={StaticResource BoolToVisibility}}"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource HeaderText}" Text="Setup" />
                    <TextBlock Style="{StaticResource SubText}"
                               Margin="0,6,0,2"
                               Text="{Binding Setup.ExtensionStepLabel}" />
                    <TextBlock Style="{StaticResource SubText}"
                               Margin="0,0,0,2"
                               Text="{Binding Setup.NmhStepLabel}" />
                    <TextBlock Style="{StaticResource SubText}"
                               Margin="0,0,0,6"
                               Text="{Binding Setup.SnapshotStepLabel}" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Install extension"
                                Style="{StaticResource HitButton}"
                                Tag="{Binding Setup.ExtensionInstallUrl}"
                                Click="OnOpenUrlFromTag" />
                        <Button Content="Run --register"
                                Style="{StaticResource HitButton}"
                                Click="OnRunRegisterClicked" />
                        <Button Content="Help"
                                Style="{StaticResource HitButton}"
                                Tag="{Binding Setup.TroubleshootingUrl}"
                                Click="OnOpenUrlFromTag" />
                        <Button Content="Dismiss 24h"
                                Style="{StaticResource HitButton}"
                                Click="OnDismissSetup"
                                ToolTip="Hide the setup card for 24 hours." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Bucket cards  -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Buckets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BucketViewModel}">
                        <Border Style="{StaticResource CardBorder}"
                                Cursor="Hand"
                                Focusable="True"
                                IsTabStop="True"
                                MouseLeftButtonUp="OnCardClicked"
                                MouseRightButtonUp="OnCardRightClicked"
                                KeyDown="OnCardKeyDown"
                                AutomationProperties.Name="{Binding HoverTooltip}"
                                AutomationProperties.HelpText="Click or press Enter to open the provider's analytics page. Right-click or press Shift+F10 to snooze.">
                            <Border.ToolTip>
                                <ToolTip>
                                    <StackPanel>
                                        <TextBlock Text="{Binding HoverTooltip}" />
                                        <TextBlock Style="{StaticResource SubText}"
                                                   Margin="0,4,0,0"
                                                   Text="{Binding PaceLabel}"
                                                   Visibility="{Binding HasPace, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0"
                                                   Text="Click → open analytics · Right-click → mute / snooze" />
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Ring with center percent overlay  -->
                                <Grid Grid.Column="0" Width="80" Height="80" Margin="0,0,12,0" Opacity="{Binding StaleOpacity}">
                                    <c:RadialRing Percent="{Binding Percent}"
                                                  Thickness="9"
                                                  PaceMarkerPercent="{Binding PaceMarkerPercent}"
                                                  ReducedMotion="{Binding DataContext.ReducedMotion, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                  TrackBrush="{StaticResource Brush.Ring.Track}"
                                                  SafeBrush="{StaticResource Brush.Ring.Safe}"
                                                  WarnBrush="{StaticResource Brush.Ring.Warn}"
                                                  DangerBrush="{StaticResource Brush.Ring.Danger}" />
                                    <!-- R3-P2-05: Viewbox-wrap so the center text scales to fit at every DPI -->
                                    <Viewbox Stretch="Uniform" Margin="14">
                                        <TextBlock Style="{StaticResource RingCenter}" Text="{Binding TimeUntilResetLabel}" />
                                    </Viewbox>
                                </Grid>

                                <!--  Labels  -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource HeaderText}">
                                        <Run Text="{Binding Provider, Mode=OneWay}" />
                                        <Run Text=" — " />
                                        <Run Text="{Binding Label, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource SubText}" Margin="0,2,0,0" Text="{Binding PercentLabel}" />
                                    <TextBlock Style="{StaticResource SubText}" Text="{Binding ResetAtLabel}" />
                                    <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0" Text="{Binding KindBadge}" />
                                    <TextBlock Style="{StaticResource MutedText}"
                                               Text="{Binding PaceLabel}"
                                               Visibility="{Binding HasPace, Converter={StaticResource BoolToVisibility}}" />
                                    <!-- NX-08: 24-sample sparkline rendered when HistoryStore has ≥2 samples for this bucket id. -->
                                    <c:Sparkline Samples="{Binding SparklineData}"
                                                 LineBrush="{StaticResource Brush.Card.MutedText}"
                                                 Height="18"
                                                 Margin="0,6,0,0"
                                                 Visibility="{Binding HasSparkline, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Settings panel (embedded, expand-down)  -->
            <StackPanel Grid.Row="3" Margin="0,4,0,0">
                <Button Style="{StaticResource HitButton}"
                        Content="{Binding Settings.ToggleGlyph}"
                        Click="OnToggleSettings"
                        HorizontalAlignment="Right" />
                <Border Style="{StaticResource CardBorder}"
                        Margin="0,4,0,0"
                        Visibility="{Binding Settings.IsExpanded, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <CheckBox Content="Notification alarms enabled"
                                  Foreground="{StaticResource Brush.Card.BodyText}"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Settings.AlarmsEnabled}" />
                        <CheckBox Content="Launch QuotaGlass at logon"
                                  Foreground="{StaticResource Brush.Card.BodyText}"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding Settings.Autostart}" />
                        <CheckBox Content="Fire pace (burn-rate) warning toasts"
                                  Foreground="{StaticResource Brush.Card.BodyText}"
                                  Margin="0,0,0,6"
                                  ToolTip="Triggers a single U2 toast per reset window when the forecast says the bucket will exhaust before reset."
                                  IsChecked="{Binding Settings.PaceEnabled}" />
                        <CheckBox Content="Respect Windows Focus Assist / DND"
                                  Foreground="{StaticResource Brush.Card.BodyText}"
                                  Margin="0,0,0,6"
                                  ToolTip="Suppresses alarm toasts while Focus Assist, fullscreen apps, or presentation mode are active. Suppressed tiers are marked fired so they don't replay later."
                                  IsChecked="{Binding Settings.RespectFocusAssist}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Style="{StaticResource SubText}"
                                       VerticalAlignment="Center"
                                       Text="Theme:" />
                            <RadioButton Content="Mocha (dark)"
                                         Foreground="{StaticResource Brush.Card.BodyText}"
                                         Margin="10,0,10,0"
                                         GroupName="QGTheme"
                                         IsChecked="{Binding Settings.IsDarkTheme, Mode=TwoWay}" />
                            <RadioButton Content="Latte (light)"
                                         Foreground="{StaticResource Brush.Card.BodyText}"
                                         GroupName="QGTheme"
                                         IsChecked="{Binding Settings.IsLightTheme, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SubText}"
                                   Text="Reset ladder (uncheck to suppress a tier):"
                                   Margin="0,6,0,2" />
                        <ItemsControl ItemsSource="{Binding Settings.LadderTiers}" Margin="0,2,0,4">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:LadderTierViewModel}">
                                    <CheckBox Content="{Binding Label}"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              Foreground="{StaticResource Brush.Card.BodyText}"
                                              Margin="0,2,10,2"
                                              ToolTip="Toggle this lead-time toast" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SubText}"
                                       VerticalAlignment="Center"
                                       Text="Custom sound:" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,6,0"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding Settings.CustomWavPath}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource HitButton}"
                                    Content="Pick…"
                                    Click="OnPickWavClicked" />
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SubText}"
                                       VerticalAlignment="Center"
                                       Text="Reset (R2) sound:" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,6,0"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding Settings.ResetWavPath}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource HitButton}"
                                    Content="Pick…"
                                    Click="OnPickResetWavClicked" />
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource SubText}"
                                       VerticalAlignment="Center"
                                       Text="Zero-state (R3) sound:" />
                            <TextBlock Grid.Column="1"
                                       Style="{StaticResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,6,0"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding Settings.ZeroStateWavPath}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource HitButton}"
                                    Content="Pick…"
                                    Click="OnPickZeroStateWavClicked" />
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SubText}" Text="Warn at %"
                                           ToolTip="Ring turns peach above this percentage." />
                                <TextBox Text="{Binding Settings.WarnPercent, UpdateSourceTrigger=LostFocus}"
                                         Background="{StaticResource Brush.Window.Background}"
                                         Foreground="{StaticResource Brush.Card.BodyText}"
                                         BorderBrush="{StaticResource Brush.Card.Border}"
                                         ToolTip="Ring turns peach above this percentage." />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource SubText}" Text="Danger at %"
                                           ToolTip="Ring turns red above this percentage." />
                                <TextBox Text="{Binding Settings.DangerPercent, UpdateSourceTrigger=LostFocus}"
                                         Background="{StaticResource Brush.Window.Background}"
                                         Foreground="{StaticResource Brush.Card.BodyText}"
                                         BorderBrush="{StaticResource Brush.Card.Border}"
                                         ToolTip="Ring turns red above this percentage." />
                            </StackPanel>
                        </Grid>
                        <!-- R4-Q-11 — reset all settings (excluding position) to factory defaults -->
                        <Button Style="{StaticResource HitButton}"
                                Content="Reset settings to defaults"
                                Click="OnResetSettings"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                ToolTip="Restores alarm ladder, thresholds, theme, etc. to factory defaults. Position is preserved." />

                        <!-- F-N7 — shell-command webhook -->
                        <TextBlock Style="{StaticResource SubText}"
                                   Text="Webhook command on alarm fire (optional):"
                                   ToolTip="Runs with cmd /c on each alarm fire. Env vars: QG_PROVIDER, QG_BUCKET_ID, QG_PERCENT, QG_RESET_ISO, QG_TIER. 5 s timeout."
                                   Margin="0,8,0,2" />
                        <TextBox Text="{Binding Settings.WebhookCommand, UpdateSourceTrigger=LostFocus}"
                                 Background="{StaticResource Brush.Window.Background}"
                                 Foreground="{StaticResource Brush.Card.BodyText}"
                                 BorderBrush="{StaticResource Brush.Card.Border}"
                                 ToolTip="e.g. curl -d \"%QG_PROVIDER% at %QG_PERCENT%%%\" https://ntfy.sh/your-topic" />

                        <!-- L-02 — 7-day next-resets calendar (collapsed by default) -->
                        <Button Style="{StaticResource HitButton}"
                                Content="{Binding Calendar.ToggleLabel}"
                                Click="OnToggleCalendar"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0" />
                        <Border BorderBrush="{StaticResource Brush.Card.Border}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6"
                                Margin="0,4,0,0"
                                Visibility="{Binding Calendar.IsExpanded, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding Calendar.Days}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CalendarDayViewModel}">
                                        <StackPanel Margin="0,0,0,6">
                                            <TextBlock Style="{StaticResource HeaderText}"
                                                       Text="{Binding Header}"
                                                       Margin="0,0,0,2" />
                                            <ItemsControl ItemsSource="{Binding Resets}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type vm:CalendarEntry}">
                                                        <TextBlock Style="{StaticResource SubText}"
                                                                   Text="{Binding Display}"
                                                                   Margin="6,0,0,2" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- NX-10 embedded log panel (collapsed by default) -->
                        <Button Style="{StaticResource HitButton}"
                                Content="{Binding LogPanel.ToggleLabel}"
                                Click="OnToggleLog"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0" />
                        <Border BorderBrush="{StaticResource Brush.Card.Border}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6"
                                Margin="0,4,0,0"
                                Visibility="{Binding LogPanel.IsExpanded, Converter={StaticResource BoolToVisibility}}">
                            <TextBox Text="{Binding LogPanel.Tail, Mode=OneWay}"
                                     IsReadOnly="True"
                                     FontFamily="{StaticResource Font.Mono}"
                                     FontSize="10"
                                     Foreground="{StaticResource Brush.Card.MutedText}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     MaxHeight="160" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!--  Status strip  -->
            <TextBlock Grid.Row="4"
                       Style="{StaticResource MutedText}"
                       Margin="2,4,2,0"
                       Text="{Binding StatusText}" />
        </Grid>
    </Border>
</Window>
